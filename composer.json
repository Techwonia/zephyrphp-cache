{
    "name": "zephyrphp/cache",
    "description": "Cache module for ZephyrPHP - Multiple cache drivers support",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "zephyrphp/framework": "^0.4"
    },
    "suggest": {
        "ext-redis": "Required for Redis cache driver",
        "ext-apcu": "Required for APCu cache driver"
    },
    "autoload": {
        "psr-4": {
            "ZephyrPHP\\Cache\\": "src/"
        }
    },
    "extra": {
        "zephyr": {
            "module": "cache",
            "config": "config/cache.php"
        }
    }
}
